{
	"name": "jlceda-inventory",
	"version": "0.1.0",
	"description": "嘉立创EDA专业版个人元器件库存管理扩展",
	"author": "bluescola",
	"license": "Apache-2.0",
	"homepage": "https://github.com/bluescola/jlceda-inventory",
	"repository": {
		"type": "git",
		"url": "https://github.com/bluescola/jlceda-inventory.git"
	},
	"engines": {
		"node": ">=20.17.0"
	},
	"scripts": {
		"compile": "rimraf ./dist/ && ts-node ./config/esbuild.prod.ts",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"lint": "eslint",
		"fix": "eslint --fix",
		"build": "npm run compile && ts-node ./build/packaged.ts"
	},
	"dependencies": {
		"papaparse": "^5.5.4"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^5.4.1",
		"@jlceda/pro-api-types": "^0.3.6",
		"@types/fs-extra": "^11.0.4",
		"@types/papaparse": "^5.5.2",
		"esbuild": "^0.24.2",
		"eslint": "^9.37.0",
		"fs-extra": "^11.3.0",
		"ignore": "^7.0.3",
		"jszip": "^3.10.1",
		"lint-staged": "^16.2.3",
		"rimraf": "^6.0.1",
		"simple-git-hooks": "^2.13.1",
		"ts-node": "^10.9.2",
		"typescript": "^5.7.3",
		"vitest": "^4.1.10"
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged"
	},
	"lint-staged": {
		"*": "eslint --fix"
	}
}
